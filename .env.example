# Copia este fichero a .env y rellena los valores.
# .env NUNCA se commitea (está en .gitignore).

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Seed global de reproducibilidad
RANDOM_SEED=42

# --- Fase 7: paper trading con OANDA practice ---
# 1. Cuenta demo en oanda.com (fxTrade Practice), balance recomendado 50.000
# 2. API key en: Mi cuenta -> Manage API Access
# 3. Account ID con formato 101-004-XXXXXXX-001
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true

# --- Telegram: informe diario + alertas de error ---
# 1. Habla con @BotFather -> /newbot -> copia el token
# 2. Envia un mensaje a tu bot
# 3. python -m gold_bot.execution.notify --discover  (imprime tu chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
